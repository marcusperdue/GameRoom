{
  "name": "gameroom",
  "version": "0.1.0",
  "private": true,
  "description": "Portable console launcher for GameCube, Wii, PS2, Xbox, Nintendo DS, PS1, and PSP.",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js",
    "scan": "node ../Scripts/scan-library.mjs",
    "init": "node ../Scripts/init-folders.mjs",
    "pack": "electron-builder --dir",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:linux": "electron-builder --linux AppImage tar.gz",
    "dist:win": "electron-builder --win nsis zip"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "local.gameroom.launcher",
    "productName": "GameRoom",
    "icon": "src/assets/icon.png",
    "directories": {
      "output": "../Downloads/Updates/builds"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "src/assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games"
    },
    "linux": {
      "icon": "src/assets/icon.png",
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Game"
    },
    "win": {
      "icon": "src/assets/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}
